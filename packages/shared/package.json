{
  "name": "nuxtseo-shared",
  "type": "module",
  "version": "0.8.1",
  "description": "Shared utilities for Nuxt SEO modules.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./content": {
      "types": "./dist/content.d.mts",
      "import": "./dist/content.mjs"
    },
    "./kit": {
      "types": "./dist/kit.d.mts",
      "import": "./dist/kit.mjs"
    },
    "./devtools": {
      "types": "./dist/devtools.d.mts",
      "import": "./dist/devtools.mjs"
    },
    "./i18n": {
      "types": "./dist/i18n.d.mts",
      "import": "./dist/i18n.mjs"
    },
    "./pro": {
      "types": "./dist/pro.d.mts",
      "import": "./dist/pro.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/module.mjs",
  "types": "./dist/types.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "dev:prepare": "nuxt-module-build prepare",
    "stub": "nuxt-module-build build --stub",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@nuxt/schema": "^3.16.0 || ^4.0.0",
    "nuxt": "^3.16.0 || ^4.0.0",
    "nuxt-site-config": "^3.2.0 || ^4.0.0",
    "vue": "^3.5.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "nuxt-site-config": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@nuxt/devtools-kit": "catalog:",
    "@nuxt/kit": "catalog:",
    "birpc": "catalog:",
    "consola": "catalog:",
    "defu": "catalog:",
    "ofetch": "catalog:",
    "pathe": "catalog:",
    "pkg-types": "catalog:",
    "radix3": "catalog:",
    "sirv": "catalog:",
    "std-env": "catalog:",
    "ufo": "catalog:"
  },
  "devDependencies": {
    "@nuxt/module-builder": "catalog:",
    "@nuxt/schema": "catalog:",
    "@nuxtjs/i18n": "catalog:",
    "nuxt-site-config": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
